# ─── GYMAWY Environment Variables ────────────────────────────────────────────
# When running in Docker, set these in docker-compose.yml instead of this file.

PORT=3000

# Generate a strong random secret. Example:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-random-secret

# ─── Stripe Configuration ─────────────────────────────────────────────────────
# 1. Create a free account at https://dashboard.stripe.com
# 2. Go to Developers → API keys
# 3. Use TEST keys (pk_test_ / sk_test_) for development
# 4. Switch to LIVE keys only for real money transactions
#
# Test card: 4242 4242 4242 4242 | any future expiry | any CVC

STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_CURRENCY=usd

# ─── App URL ──────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
